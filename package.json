{
  "name": "medical-billing-dispute-letters-ai",
  "version": "1.0.0",
  "description": "AI-powered medical billing dispute letter generator with verified CPT/ICD-10 codes",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhouston2019/medicalbillingletters.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run copy-html",
    "copy-html": "copyfiles *.html dist/ && copyfiles styles.css dist/",
