{
  "name": "autoclaimnavigatorai",
  "version": "2.0.0",
  "description": "AI-powered auto insurance claim documentation platform",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "dev": "netlify dev",
    "build": "npm run test && npm run generate-sitemap",
    "generate-sitemap": "node scripts/generate-sitemap.js",
    "backup": "node scripts/backup-data.js",
    "restore": "node scripts/restore-data.js",
    "monitor": "node scripts/monitor-health.js"
  },
  "keywords": [
    "auto insurance claims",
    "total loss disputes",
    "diminished value claims",
    "vehicle valuation",
    "insurance appeals",
    "auto claim AI",
    "repair supplements",
    "OEM parts disputes"
  ],
  "author": "AutoClaimNavigatorAI",
  "license": "Proprietary",
  "dependencies": {
    "@netlify/blobs": "^7.0.0",
    "@netlify/functions": "^2.4.0",
    "@sendgrid/mail": "^8.1.0",
    "@sentry/serverless": "^7.88.0",
    "stripe": "^14.10.0",
    "openai": "^4.24.1",
    "pdfkit": "^0.14.0",
    "docx": "^8.4.0",
    "ioredis": "^5.3.2",
    "dompurify": "^3.0.8",
    "isomorphic-dompurify": "^2.3.0",
    "jsonwebtoken": "^9.0.2",
    "rate-limiter-flexible": "^3.0.6",
    "validator": "^13.11.0",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "node-cache": "^5.1.2",
    "winston": "^3.11.0",
    "axios": "^1.6.3",
    "cheerio": "^1.0.0-rc.12",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "@testing-library/jest-dom": "^6.1.5",
    "supertest": "^6.3.3",
    "eslint": "^8.56.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "prettier": "^3.1.1",
    "husky": "^8.0.3",
    "lint-staged": "^15.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "coverageDirectory": "./coverage",
    "collectCoverageFrom": [
      "netlify/functions/**/*.js",
      "!netlify/functions/**/*.test.js"
    ]
  },
  "lint-staged": {
    "*.js": ["eslint --fix", "prettier --write"]
  }
}